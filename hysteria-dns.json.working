      "password": "eb5be46702b83b5177a7c057a68509d6",
      "tls": {
        "enabled": true,
        "server_name": "www.apple.com",
        "insecure": true
      }
    }
  ],
  "route": {
    "final": "hysteria-out",
    "auto_detect_interface": true
  }
