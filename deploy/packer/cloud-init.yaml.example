#cloud-config
# Pass this as user-data when creating a VPS from the pre-baked image.
# The config.json content should be customized per server.

write_files:
  - path: /etc/lantern-box/config.json
    permissions: "0600"
    content: |
      {
        "log": { "level": "info" },
        "inbounds": [
          {
            "type": "algeneva",
            "listen": "::",
            "listen_port": 9001,
            "strategy": "[HTTP:host:*]-changecase{lower}-|"
          }
        ],
        "outbounds": [
          { "type": "direct" }
        ]
      }

  # Optional: proxy info for telemetry
  - path: /etc/lantern-box/config.ini
    permissions: "0600"
    content: |
      proxyname = my-proxy-01
      pro = false
      track = stable
      provider = digitalocean
      proxyprotocol = algeneva

  # OTel env for the lantern-box process — send to the local collector.
  - path: /etc/lantern-box/otel.env
    permissions: "0600"
    content: |
      OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

  # OTel resource attributes for the sidecar collector (host metrics, logs).
  - path: /etc/otelcol-contrib/otelcol.env
    permissions: "0600"
    content: |
      OTEL_RESOURCE_ATTRIBUTES=host.name=my-proxy-01,cloud.provider=digitalocean

runcmd:
  - systemctl enable --now otelcol-contrib
  - systemctl enable --now lantern-box
