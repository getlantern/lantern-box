{
  "log": {
    "level": "debug"
  },
  "inbounds": [
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "listen_port": 1080
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "unbounded",
      "tag": "unbounded-out",
      "discovery_srv": "http://127.0.0.1:9000",
      "discovery_endpoint": "/v1/signal",
      "insecure_do_not_verify_client_cert": true
    }
  ],
  "route": {
    "rules": [
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "final": "unbounded-out",
    "auto_detect_interface": true
  }
}
