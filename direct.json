{
  "log": {
    "level": "trace",
    "output": "stdout",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "utun225",
      "mtu": 1500,
      "address": [
        "10.10.1.1/30",
        "fdf0:f3e1:fdd::1/126"
      ],
      "auto_route": true,
      "strict_route": true,
      "sniff": true
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct",
      "bind_interface": "en0"
    }
  ],
  "route": {
    "rules": [
      { 
        "process_path_regex": ".*lantern-box.*", 
        "outbound": "direct"
      },
      { 
        "protocol": "dns",
        "outbound": "direct" 
      },
      { 
        "ip_is_private": true, 
        "outbound": "direct" 
      },
      {
        "inbound": "tun-in",
        "outbound": "direct"
      }
    ],
    "auto_detect_interface": true
  }
}